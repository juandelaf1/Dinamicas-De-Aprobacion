{"uri": "at://did:plc:wry3kwhzw56muq77e663zaz3/app.bsky.feed.post/3mnxopppgpu2x", "parent_uri": null, "author_did": "did:plc:wry3kwhzw56muq77e663zaz3", "author_handle": "cfr.org", "author_name": "Council on Foreign Relations", "text": "President Trump signed a memorandum on June 5 directing U.S. national security agencies to accelerate artificial intelligence adoption and revoking certain restrictions imposed by the Biden administration.\n\nExperts Vinh Nguyen and Michael Horowitz assess Trump’s new national security AI directive:", "timestamp": "2026-06-10T21:45:59.970582977Z", "likes": 2, "replies_count": 1, "reposts": 2, "depth": 0, "is_root": true}
