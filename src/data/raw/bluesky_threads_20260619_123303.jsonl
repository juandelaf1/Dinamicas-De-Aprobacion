{"uri": "at://did:plc:mo5ygs7v7bkqypewszyndc3w/app.bsky.feed.post/3mnxstnznao2a", "parent_uri": null, "author_did": "did:plc:mo5ygs7v7bkqypewszyndc3w", "author_handle": "maugrim.bsky.social", "author_name": "Maug 🐺", "text": "Similar legislation is racing through different states and at the federal level across the pond. What the US does with its technology is often copied across the globe. These laws would cause dangerous ripple effects worldwide.", "timestamp": "2026-06-10T22:59:37.143Z", "likes": 1, "replies_count": 1, "reposts": 0, "depth": 0, "is_root": true}
